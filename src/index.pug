        include template/_pmod_head_metadata.pug
        include template/_pmod_mixins.pug
        +og_generator("sudoker0", "my website.", "/")

        link(rel="stylesheet", href="/website/style/index.css")
        script(src="/website/script/index.js" defer)

    body(data-js="false")
