            .social_links
                +social_link_item("discord", "https://discord.com/users/763377551963717653", "sudoker0")
                +social_link_item("github", "https://github.com/sudoker0", "sudoker0")
                +social_link_item("steam", "https://steamcommunity.com/id/sudoker0/", "sudoker0")
                +social_link_item("reddit", "https://old.reddit.com/user/Quan_MCPC", "Quan_MCPC")
                +social_link_item("itch.io", "https://sudoker0.itch.io", "sudoker0.itch.io")
                +social_link_item("mastodon", "https://mastodon.world/@quanmcpc", "@QuanMCPC")
                +social_link_item("bsky", "https://bsky.app/profile/sudoker0.xyz")
                +social_link_item("bandcamp", " https://bandcamp.com/sudoker0", "sudoker0")
                +social_link_item("planet_minecraft", "https://www.planetminecraft.com/member/sudoker0/", "sudoker0")

        +section("about_me", "", "/About_Me", "")
            .split_container.l
                .left
                    p I am a #[span.highlight-blue web developer] with skills in front-end and back-end development. I have created many websites, APIs and browser apps during my #[span.highlight-red 8 years] of programming.
                    p I have made #[span.highlight-blue games] using Godot, #[span.highlight-green programs] using C++/C#, #[span.highlight-red websites] using frameworks such as Svelte or Express, as well as #[span.highlight-cyan mobile app] using Flutter.
                    p I have won many regional #[span.highlight-green programming competitions] in my country, and I am constantly learning to improve my programming skills and gain experience for future competitions.
                .right
                    .card.hover_effect
                        #text_container(tabindex="0")
                            p
                            #shadow
                            img(src="website/image/logo/logo_transparent.png", alt="logo")

        +section("skills", "", "/Programming_Skills")
            p These are languages which I am #[span.highlight-red skilled] in. While I have used numerous different programming languages before, these are the one that I can use with ease.
            .skills_container
