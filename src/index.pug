                    p TypeScript
                .card.hover_effect(data-colorOverride="#FFE873")
                    img(src="/website/image/index_page/programming_language_logo/python.svg", alt="Python logo")
                    p Python
                .card.hover_effect(data-colorOverride="#659ad2")
